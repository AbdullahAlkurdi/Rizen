{
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{"source": "**", "destination": "/index.html"}],
    "headers": [
      {"source": "/**", "headers": [{"key": "Cache-Control", "value": "public, max-age=3600"}]},
      {"source": "*.dart.js", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]}
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "titan-rizen",
          "appId": "1:979363811566:android:140e901c5d439e9a07a3ff",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "titan-rizen",
          "configurations": {
            "android": "1:979363811566:android:140e901c5d439e9a07a3ff",
            "ios": "1:979363811566:ios:dbaf65c919cfc50707a3ff",
